{
  "compileOnSave": false,
  "compilerOptions": {
    "importHelpers": true,
    "module": "es2022",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "target": "es2020",
    "types": ["node", "@playwright/test"],
    // "typeRoots": [
    //   "./types", "node_modules/@types"
    // ],
    "lib": [
      "es2022",
      "dom"
    ],
    "plugins": [
      { "name": "tslint-language-service"}
    ]
  }
}
